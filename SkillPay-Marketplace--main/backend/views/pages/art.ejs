<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Art Section | SkillPay</title><script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script><link rel="stylesheet" href="/static/art.css">
</head><body class="bg-gray-50">
<%- include('../partials/header') %>
<div class="css-tab-wrapper">
<input type="radio" name="art-category" id="radio-sketches" class="category-toggle" checked>
<input type="radio" name="art-category" id="radio-sculptures" class="category-toggle">
<input type="radio" name="art-category" id="radio-paintings" class="category-toggle">
<input type="radio" name="art-category" id="radio-arts" class="category-toggle">
<input type="radio" name="art-category" id="radio-photographs" class="category-toggle">
<input type="radio" name="art-category" id="radio-newArrivals" class="category-toggle">
<div class="container mx-auto px-4 sm:px-6 lg:px-8 mt-6"><div class="flex flex-col md:flex-row gap-8">
<aside class="md:w-64 flex-shrink-0"><div class="sticky top-24">
<h3 class="text-lg font-bold text-gray-800 mb-4">Categories</h3>
<div class="flex flex-row md:flex-col overflow-x-auto md:overflow-x-visible pb-2 md:pb-0">
<label for="radio-sketches" class="sidebar-btn">Sketches</label>
<label for="radio-sculptures" class="sidebar-btn">Sculptures</label>
<label for="radio-paintings" class="sidebar-btn">Paintings</label>
<label for="radio-arts" class="sidebar-btn">Arts</label>
<label for="radio-photographs" class="sidebar-btn">Photographs</label>
<label for="radio-newArrivals" class="sidebar-btn">New Arrivals</label>
</div></div></aside>
<main class="flex-1"><div>
<div id="section-sketches" class="gallery-section"><div class="gallery" id="sketches-gallery"></div></div>
<div id="section-sculptures" class="gallery-section"><div class="gallery" id="sculptures-gallery"></div></div>
<div id="section-paintings" class="gallery-section"><div class="gallery" id="paintings-gallery"></div></div>
<div id="section-arts" class="gallery-section"><div class="gallery" id="arts-gallery"></div></div>
<div id="section-photographs" class="gallery-section"><div class="gallery" id="photographs-gallery"></div></div>
<div id="section-newArrivals" class="gallery-section"><div class="gallery" id="newArrivals-gallery"></div></div>
</div></main></div></div></div>
<script>lucide.createIcons();</script><script src="/static/art.js" defer></script>
<%- include('../partials/footer') %>
</body></html>